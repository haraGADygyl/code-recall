# The directory containing your markdown articles
ARTICLES_DIR="./articles"

# Default LLM provider: "openai" or "ollama"
DEFAULT_PROVIDER="openai"

# Default question mode: "articles", "rest-api", "fastapi", or "system-design"
DEFAULT_QUESTION_MODE="system-design"

# OpenAI Configuration
OPENAI_API_KEY=""
OPENAI_MODEL_NAME="gpt-4.1-mini"
OPENAI_TIMEOUT_SECONDS="45"
OPENAI_MAX_RETRIES="1"

# Ollama Configuration
MODEL_NAME="gemma2:2b"
OLLAMA_TIMEOUT_SECONDS="120"
OLLAMA_PROBE_TIMEOUT_SECONDS="5"
OLLAMA_KEEP_ALIVE="0"

# Article privacy. Article contents are never sent to OpenAI unless enabled.
ALLOW_REMOTE_ARTICLES="false"
MAX_ARTICLE_BYTES="262144"

# Optional directories to prepend to PATH in recall.sh
# EXTRA_PATH="/custom/bin"
